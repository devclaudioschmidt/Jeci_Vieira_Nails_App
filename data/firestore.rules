rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------
    // USUARIOS
    // -------------------
    match /usuarios/{userId} {
      // Admin: acesso total
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      // Proprio usuario: pode ler e editar proprio perfil
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Leitura pública de clientes (necessário para buscar por telefone no agendamento)
      allow read: if resource.data.role == 'cliente';
      // Qualquer pessoa pode criar um novo cliente (fluxo público de agendamento)
      allow create: if request.resource.data.role == 'cliente'
                    && request.resource.data.nome is string
                    && request.resource.data.nome != '';
    }
    
    // -------------------
    // AGENDAMENTOS
    // -------------------
    match /agendamentos/{agendamentoId} {
      // Admin: acesso total
      allow read, write, delete: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      // Leitura pública (para verificar horários ocupados no fluxo de agendamento)
      allow read: if true;
      // Qualquer pessoa pode criar um agendamento (fluxo público)
      allow create: if request.resource.data.servicoNome is string
                    && request.resource.data.userId is string
                    && request.resource.data.data is string
                    && request.resource.data.horario is string
                    && request.resource.data.status == 'pendente';
      // Cliente autenticado: atualizar propio agendamento (cancelar)
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      // Público: pode deletar agendamento pendente (ex: reagendamento)
      allow delete: if resource.data.status == 'pendente';
    }
    
    // -------------------
    // SERVICOS
    // -------------------
    match /servicos/{servicoId} {
      // Leitura pública (clientes não precisam de login)
      allow read: if true;
      // Apenas admin pode criar, editar, excluir
      allow create, write, delete: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }
    
    // -------------------
    // CONFIGURACOES
    // -------------------
    match /configuracoes/{configId} {
      // Leitura pública (clientes não precisam de login)
      allow read: if true;
      // Apenas admin pode editar
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }
    
    // -------------------
    // AVISOS
    // -------------------
    match /avisos/{avisoId} {
      // Leitura pública (clientes não precisam de login)
      allow read: if true;
      // Apenas admin pode criar, editar, excluir
      allow create, write, delete: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }
    
    // -------------------
    // NOTIFICACOES
    // -------------------
    match /notificacoes/{notificacaoId} {
      // Proprio usuario pode ler suas notificacoes
      allow read, create: if request.auth != null && request.auth.uid == notificacaoId;
      // Admin pode ler e criar todas
      allow read, create: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }
  }
}